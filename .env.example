# .env.example

# ==============================================================================
# ENVIRONMENT VARIABLES SETUP
# 1. DO NOT commit actual secrets (API keys, URIs) to this file or any .env file 
#    that is pushed to GitHub.
# 2. Add this file to your repository as a template for other developers (or yourself).
# 3. For local development, copy this file to `.env.local` and add real keys.
# 4. For production, add the real keys directly in your hosting dashboard under 
#    "Environment Variables" settings (e.g. Vercel dashboard).
# ==============================================================================

# Client-Side Variables (Must be prefixed with NEXT_PUBLIC_ in Next.js)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=YOUR_EMAILJS_SERVICE_ID_HERE
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=YOUR_EMAILJS_TEMPLATE_ID_HERE
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=YOUR_EMAILJS_PUBLIC_KEY_HERE

# Server-Side Variables (Only accessible in Node.js environments / API routes)
# Do NOT use NEXT_PUBLIC_ for sensitive backend items like DB URIs
MONGODB_URI=YOUR_MONGODB_URI_HERE
FORMSPREE_PROJECT_ID=YOUR_FORMSPREE_PROJECT_ID_HERE
